{
	"compilerOptions": {
		"allowJs": true,
		"experimentalDecorators": true,
		"module": "esnext",
		"lib": [
			"es2024",
			"dom"
		],
		"target": "es2024",
		"moduleResolution": "bundler",
		"outDir": "build",
		"strict": true,
		"noImplicitAny": true,
		"removeComments": true,
		"noImplicitReturns": false,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"allowUnreachableCode": true,
		"strictNullChecks": false,
		"esModuleInterop": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"noEmit": true,
		"incremental": true,
		"isolatedModules": true,
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"exclude": [
		"node_modules",
		"dist"
	],
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts",
		"**/*.ts",
		"**/*.tsx",
		"dist/types/**/*.ts",
		"dist/dev/types/**/*.ts"
	]
}
